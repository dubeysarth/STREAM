{
  "data": {
    "dataset_name": "v1_HUC-ALL_W6_L6_1989-2008_WY",
    "region": "continental_us",
    "resolution": "monthly_shared_huc_all",
    "manifest_path": "configs/manifests/us_monthly_huc_all.json"
  },
  "task": {
    "name": "08_run_lumped_baseline",
    "representation": "lumped",
    "target": "GloFAS_surrogate_outlet"
  },
  "model": {
    "name": "monthly_lumped_outlet_baseline",
    "checkpoint": "outputs/08_lumped_baseline/model_best.pt",
    "notes": "Shared monthly outlet baseline on the same split used by distributed monthly experiments.",
    "dynamic_group": "era5_core_plus_snow",
    "loss_name": "hydro_skill",
    "history_length": 12
  },
  "runtime": {
    "device": "cuda:0",
    "seed": 42,
    "compute_budget": "targeted_1_gpu"
  },
  "outputs": {
    "root": "outputs/08_lumped_baseline",
    "summary_table": "outputs/08_lumped_baseline/us_monthly_outlet_summary.csv"
  },
  "rebuttal": {
    "mode": "aggressive_best_case",
    "shared_repo_url": "<SHARED_REPO_URL>"
  }
}
